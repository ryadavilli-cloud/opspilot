# Keep the build context lean — the image needs pyproject/uv.lock/README, src/, and only the
# operational runtime data (data/synthetic + data/kb). Everything else is excluded.
.git
.gitignore
.venv
venv
**/__pycache__
**/*.py[cod]
.pytest_cache
.mypy_cache
.ruff_cache
.python-version

# Not needed in the image
docs
infra
.github
tests
eval
*.pdf
.vs
.vscode
.idea
out.txt
raw.txt

# Data: only data/synthetic (json corpus) and data/kb (markdown) are packaged by the Dockerfile.
# Exclude the answer key, distractors, calibration profiles/caches, provenance, and generators —
# none belong in a deterministic runtime image.
data/answer_key
data/distractors
data/profiles
data/.rcaeval_cache
data/provenance.md
data/synthetic/*.py

# Secrets / local env
.env
.env.*
!.env.example
