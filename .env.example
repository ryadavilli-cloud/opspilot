# Copy to .env and fill in. Never commit the real .env (see .gitignore).

# Runtime
OPSPILOT_ENV=local                 # local | dev | prod

# Local dev model (Ollama, OpenAI-compatible endpoint)
OPSPILOT_DEV_MODEL=qwen3:8b        # fits CPU-only on ~16GB RAM; has tool-calling
OLLAMA_BASE_URL=http://localhost:11434/v1

# Cross-vendor judge (eval only)
OPSPILOT_JUDGE_MODEL=gpt-4.1

# Production severity-tier escalation (Opus). OFF by default.
OPSPILOT_ENABLE_OPUS_SEV1=false

# Agentic loop controls
OPSPILOT_MAX_DIAGNOSE_ITERS=5
OPSPILOT_CONFIDENCE_THRESHOLD=0.75

# Azure Foundry (prod) — leave blank locally
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=

# Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
