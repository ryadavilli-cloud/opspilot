# Copy to .env and fill in. Never commit the real .env (see .gitignore).
# Keep comments on their own lines: a blank value with a trailing `# comment` is captured as the
# value by python-dotenv, so `KEY=` lines here are intentionally comment-free.

# Runtime: local | dev | prod
OPSPILOT_ENV=local

# Local dev model (Ollama, OpenAI-compatible endpoint). qwen3:8b fits CPU-only on ~16GB RAM.
OPSPILOT_DEV_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434/v1

# LLM provider seam (Stage 4). Default = local Ollama (free qwen floor). Switch to the `openai`
# provider for the gpt-4o-mini eval headline; the client is OpenAI-compatible, so the same knobs
# point at Ollama, OpenAI, or Azure Foundry — only base_url/api_key/model change.
# OPSPILOT_LLM_PROVIDER: ollama | openai | replay
OPSPILOT_LLM_PROVIDER=ollama
# OPSPILOT_LLM_MODEL: leave blank to use OPSPILOT_DEV_MODEL (qwen3:8b)
OPSPILOT_LLM_MODEL=
# OPSPILOT_LLM_BASE_URL: leave blank for the provider default (Ollama / api.openai.com)
OPSPILOT_LLM_BASE_URL=
# OPSPILOT_LLM_API_KEY: leave blank to fall back to OPENAI_API_KEY below
OPSPILOT_LLM_API_KEY=
# gpt-4o-mini headline key — set locally, never commit
OPENAI_API_KEY=

# Cross-vendor judge (eval only)
OPSPILOT_JUDGE_MODEL=gpt-4.1

# Production severity-tier escalation (Opus). OFF by default.
OPSPILOT_ENABLE_OPUS_SEV1=false

# Agentic loop controls
OPSPILOT_MAX_DIAGNOSE_ITERS=5
OPSPILOT_CONFIDENCE_THRESHOLD=0.75

# Azure Foundry (prod) — leave blank locally
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=

# Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
