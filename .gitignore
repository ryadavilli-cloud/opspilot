# ─────────────────────────────────────────────────────────────
# OpsPilot .gitignore  (Python / LangGraph / Azure)
# ─────────────────────────────────────────────────────────────

# ── Secrets & credentials  (NEVER commit) ──────────────────────
.env
.env.*
# keep a checked-in template
!.env.example
*.pem
*.key
*.pfx
*.p12
secrets.*
**/azure.json
**/*service-principal*.json
# azure-cli / azd local state; Azure Functions local config
.azure/
local.settings.json
.langsmith
.langsmith.env

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / lint / type-check caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyre/
.dmypy.json

# ── Notebooks ──────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Local model weights & vector stores  (large; not source) ───
# Keep golden/synthetic eval *datasets* tracked — ignore only heavy artifacts.
qdrant_storage/
# Raw third-party datasets (RCAEval, CC-BY-4.0) — cited in data/provenance.md.
# Only the derived profile (data/profiles/*.json) is committed, never the raw GBs.
data/.rcaeval_cache/
*.gguf
*.bin
*.safetensors
*.onnx
models/
.cache/
.huggingface/

# ── Logs, traces, eval outputs ─────────────────────────────────
*.log
logs/
eval_runs/
eval_results/
scorecards/

# ── IaC / build artifacts ──────────────────────────────────────
# Bicep compiles to ARM JSON — ignore generated output, keep the .bicep source.
*.azrm.json
main.json
.bicep/

# ── Docker ─────────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE / editor ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS cruft ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Course materials & local scratch (not for the public repo) ──
*.pdf
.vs/
out.txt
raw.txt
